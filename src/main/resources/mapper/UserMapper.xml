<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.travelfamilies.mapper.UserMapper">
    <select id="getUser" resultType="com.travelfamilies.response.GetUserResponse">
        select id, nickname, avatar
        from user_detail
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>

    </select>


    <select id="queryUser" resultType="com.travelfamilies.pojo.User">
        select
        *
        from user_detail
        <where>
            <choose>
                <!-- 优先匹配精确查询：白名单校验列名，防止 SQL 注入 -->
                <when test="key != null and value != null">
                    <choose>
                        <when test="key == 'username'">AND username = #{value}</when>
                        <when test="key == 'nickname'">AND nickname = #{value}</when>
                        <when test="key == 'email'">AND email = #{value}</when>
                        <when test="key == 'phone'">AND phone = #{value}</when>
                        <when test="key == 'role'">AND role = #{value}</when>
                        <when test="key == 'status'">AND status = #{value}</when>
                        <otherwise>AND 1 = 0</otherwise>
                    </choose>
                </when>

                <!-- 否则匹配模糊查询：如果 keyword 不为空 -->
                <otherwise>
                    <if test="keyword != null and keyword != ''">
                        AND (
                        CONCAT(username, nickname, email,phone) LIKE CONCAT('%', #{keyword}, '%')
                        )
                    </if>
                </otherwise>
            </choose>

        </where>
    </select>
</mapper>